# JSON credentials path to access Google Sheets
# Download service account credentials from Google Cloud Console
# and save as this filename
# IMPORTANT: Share your spreadsheet with the service account email (client_email in the JSON)
GOOGLE_CREDS=sheets.json

# The ID of the spreadsheet where your translation is going to happen
# Get this from the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=<your-google-sheets-spreadsheet-id>

# Where to get the source properties files from
SOURCE_DIR=source

# Source language code (must match the suffix in your .properties files)
SOURCE_LANG=en

# Target language code (for the translation column)
TARGET_LANG=ru

# File with helpful context tips for machine translation (optional)
# This will be used for LLM translation & validation
#TRANSLATION_CONTEXT=context.md

# Credentials for machine translation/validation
# Any OpenAI-compatible endpoint should work
# Consult provider documentation for details
OPENAI_API_ENDPOINT=https://api.openai.com/v1
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=<model-to-use>
OPENAI_TEMPERATURE=0.2

# Where to put the localized files (used in Part 3)
TARGET_DIR=target

# If true, the localization will also be packed (optional, used in Part 3)
# from `TARGET_DIR` to `catechesis-$TARGET_LANG.zip` in your current directory
#PACK_LOCALIZATION=true
